# Scorix Project Makefile
# Generated by scorix.
#
# Override SCORIX_CLI to point at an installed scorix binary, e.g.:
#   make gen SCORIX_CLI=scorix
SCORIX_CLI ?= go run ../scorix/cli/main.go

gen:
	$(SCORIX_CLI) generate proto -d . --force
	$(SCORIX_CLI) generate model -d . --force

shell-build:
	cd shell && pnpm build

shell-dev:
	cd shell && pnpm dev

run:
	go run . -mode=desktop -assets=shell/dist

run-web:
	go run . -mode=web -assets=shell/dist

build:
	cd shell && pnpm build
	go build -o dist/{{ .Name }} .

.PHONY: gen shell-build shell-dev run run-web build
